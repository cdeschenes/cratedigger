# ─────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────

# Last.fm API key — get one free at https://www.last.fm/api
LASTFM_API_KEY=

# Web app login password (Docker only) — login is blocked if left blank
AUTH_USER=admin
AUTH_PASS=

# Session cookie signing key — use any long random string
SECRET_KEY=


# ─────────────────────────────────────────────
# MUSIC LIBRARY
# ─────────────────────────────────────────────

# Option A — Navidrome (recommended: faster, metadata-aware)
# All three must be set to use Navidrome; leave blank to fall back to filesystem scan.
NAVIDROME_URL=http://navidrome.yourdomain.com
NAVIDROME_USER=
NAVIDROME_PASS=
# Restrict to one library by name (leave blank to scan all)
NAVIDROME_MUSIC_FOLDER=

# Option B — Local filesystem scan
# Docker: uncomment the volume line in docker-compose.yaml and set path to /music
# CLI:    set this to your actual music directory
MUSIC_ROOT=/path/to/your/music


# ─────────────────────────────────────────────
# OPTIONAL — Streaming integrations
# ─────────────────────────────────────────────

# Spotify embeds in the report viewer
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube embeds in the report viewer (requires Data API v3 key)
YOUTUBE_API_KEY=

# SLSKD (Soulseek) — enables one-click search from every card
SLSKD_URL=https://slskd.yourdomain.com
SLSKD_API_KEY=


# ─────────────────────────────────────────────
# OPTIONAL — Tuning (defaults shown)
# ─────────────────────────────────────────────

FUZZ_THRESHOLD=90
DEFAULT_WORKERS=4
MAX_WORKERS=8
TOP_ALBUM_LIMIT=25
REQUEST_TIMEOUT=15
REQUEST_DELAY_MIN=0.15
REQUEST_DELAY_MAX=0.3
MAX_RETRIES=3

# Cron schedule for automatic runs (Docker only). Leave blank to disable.
# Example: 0 3 * * 0  →  every Sunday at 3 AM
SCHEDULE_MISSING=
SCHEDULE_DISCOVER=

# Similarity scoring: lastfm (default) or tags (genre-based Jaccard scoring)
DISCOVER_SIMILARITY_MODE=lastfm
DISCOVER_TAG_OVERLAP=1
# Number of top (highest-weight) Last.fm tags used for matching in tags mode (1–10).
# Tags are sorted by weight; top 5 gives the strongest genre signal with least noise.
DISCOVER_TAG_TOP_N=5
# Minimum Jaccard tag-overlap score (0.0–1.0) required in tags mode.
# 0.1 = candidate must share ≥10% of top-N tag set with a source artist.
DISCOVER_MIN_JACCARD=0.1
SIMILAR_ARTIST_LIMIT=30
SUGGESTIONS_PER_ARTIST=2

# New & Trending section data sources (comma-separated: spotify,lastfm,bandcamp).
# Leave empty to hide the section entirely.
TRENDING_FEEDS=spotify,lastfm,bandcamp
