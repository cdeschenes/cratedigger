# Configuration for missing_popular_albums.py and discover_similar_artists.py
MUSIC_ROOT=/Volumes/NAS/Media/Music/Music_Server
HTML_OUT=missing_popular_albums.html
CACHE_FILE=.cache/lastfm_top_albums.json
LOG_FILE=missing_popular_albums.log
FUZZ_THRESHOLD=90
DEFAULT_WORKERS=4
MAX_WORKERS=8
TOP_ALBUM_LIMIT=25
TAG_INFO_CHECK_TOP_N=3
CACHE_VERSION=2
REQUEST_TIMEOUT=15
REQUEST_DELAY_MIN=0.15
REQUEST_DELAY_MAX=0.3
MAX_RETRIES=3
LASTFM_API_KEY=

# Spotify or YouTube
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_API_KEY=

# Navidrome integration (optional — if set, replaces slow NAS filesystem scan)
NAVIDROME_URL=http://navidrome.yourdomain.com
NAVIDROME_USER=
NAVIDROME_PASS=
# Leave empty to scan all libraries, or set to a library name (e.g. music_main)
NAVIDROME_MUSIC_FOLDER=

# discover_similar_artists.py settings (all optional — defaults shown)
DISCOVER_HTML_OUT=discover_similar_artists.html
DISCOVER_CACHE_FILE=.cache/similar_artists.json
DISCOVER_LOG_FILE=discover_similar_artists.log
SUGGESTIONS_PER_ARTIST=2
SIMILAR_ARTIST_LIMIT=30
# Minimum overlapping Last.fm genre tags required between candidate and source (0 = disabled)
DISCOVER_TAG_OVERLAP=1
# Similarity scoring method: lastfm (default, sort by shared-listener score) or
# tags (re-score by genre tag Jaccard similarity; zero-overlap matches are excluded)
DISCOVER_SIMILARITY_MODE=lastfm

# SLSKD Implementation
SLSKD_URL=https://slskd.yourdomain.com
SLSKD_API_KEY=your-api-key-from-appsettings
